# Google API key with these APIs enabled:
#   - Geocoding API
#   - Street View Static API
# This key is SECRET — never expose it to the frontend
GOOGLE_API_KEY=your_server_side_google_key_here

# Separate Google API key for Maps JS SDK (Places autocomplete)
# Restrict this key in Google Cloud Console to:
#   - Maps JavaScript API + Places API only
#   - HTTP referrers: your-domain.com/*
# This key IS sent to the browser but is safe when properly restricted
MAPS_JS_KEY=your_maps_js_key_here

# Your deployed frontend URL (for CORS)
# During local dev use: http://localhost:3000
# In production use your actual domain: https://yourdomain.com
ALLOWED_ORIGIN=http://localhost:3000

# Port (defaults to 3001 if not set)
PORT=3001
